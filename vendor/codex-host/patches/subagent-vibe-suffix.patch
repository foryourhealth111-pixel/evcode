+fn append_vibe_suffix_to_input_items(items: &mut Vec<UserInput>) {
+    for item in items.iter_mut() {
+        let UserInput::Text { text, .. } = item else {
+            continue;
+        };
+        let trimmed = text.trim_end();
+        if trimmed.ends_with("$vibe") {
+            return;
+        }
+        if trimmed.is_empty() {
+            *text = "$vibe".to_string();
+        } else {
+            *text = format!("{trimmed} $vibe");
+        }
+        return;
+    }
+    items.push(UserInput::Text {
+        text: "$vibe".to_string(),
+        text_elements: Vec::new(),
+    });
+}
