# Canonical local assistant-provider overrides for EvCode.
# Copy this file to config/assistant-providers.env.local and fill in your real values.
# Shell environment variables still take precedence over this file.

# Enable live advisory specialists in the standard channel.
EVCODE_ENABLE_LIVE_SPECIALISTS=1

# Shared credential used by the current RightCodes Codex / Claude / Gemini distributor paths.
EVCODE_RIGHTCODES_API_KEY=replace-with-live-key

# Codex executor defaults.
EVCODE_CODEX_BASE_URL=https://right.codes/codex/v1
EVCODE_CODEX_MODEL=gpt-5.4

# Claude advisory specialist defaults.
EVCODE_CLAUDE_BASE_URL=https://right.codes/claude-aws
EVCODE_CLAUDE_MODEL=claude-opus-4-6

# Gemini advisory specialist defaults.
EVCODE_GEMINI_BASE_URL=https://right.codes/gemini/v1
EVCODE_GEMINI_MODEL=gemini-2.5-pro
